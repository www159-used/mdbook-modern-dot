{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(deps)"
  ],
  "timezone": "Asia/Shanghai",
  "schedule": ["before 6am on Monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group mdBook crates — usually bump together",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["mdbook-preprocessor", "mdbook-markdown"],
      "groupName": "mdbook"
    },
    {
      "description": "All other Rust crates",
      "matchManagers": ["cargo"],
      "excludePackageNames": ["mdbook-preprocessor", "mdbook-markdown"],
      "groupName": "rust dependencies"
    },
    {
      "description": "CI workflow action pins",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  }
}
